{
  "family": "myresumeapp_td",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "cpu": "512",
  "memory": "700",
  "executionRoleArn": "arn:aws:iam::106601314275:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::106601314275:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "richy_resume_container",
      "image": "106601314275.dkr.ecr.ap-southeast-1.amazonaws.com/jomacs-githubactions-assignment-repo:latest",
      "cpu": 512,
      "memory": 700,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/myresumeapp_td",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}